{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.boardmark.dev/style-pack.schema.json",
  "title": "Boardmark Style Pack",
  "description": "Component-independent semantic design token foundation collection for Boardmark style packs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "namespace", "defaultFoundation", "foundations"],
  "properties": {
    "kind": {
      "const": "boardmark.style-pack"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "namespace": {
      "$ref": "#/$defs/namespace"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "defaultFoundation": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "foundations": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/foundation"
      }
    }
  },
  "$defs": {
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "foundation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokens"],
      "properties": {
        "tokens": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^(color|font|space|radius|shadow)(\\.[a-z][a-z0-9_-]*)+$"
          },
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "extends": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
