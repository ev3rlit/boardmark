{
  "name": "boardmark",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "pnpm --filter @boardmark/desktop dev",
    "dev:web": "pnpm --filter @boardmark/web dev",
    "build": "pnpm --filter @boardmark/desktop build && pnpm --filter @boardmark/web build",
    "build:web": "pnpm --filter @boardmark/web build",
    "preview:web": "pnpm --filter @boardmark/web preview",
    "preview:web:lan": "pnpm --filter @boardmark/web preview:lan",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@types/js-yaml": "^4.0.9",
    "@xyflow/react": "^12.8.5",
    "electron": "^35.1.5",
    "html-to-image": "^1.11.11",
    "js-yaml": "^4.1.1",
    "mermaid": "^11.14.0",
    "neverthrow": "^8.2.0",
    "p-queue": "^8.1.0",
    "pino": "^9.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.9"
  }
}
